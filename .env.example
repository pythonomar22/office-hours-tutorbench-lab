# Candidate model API keys. Fill only the providers you use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
FIREWORKS_API_KEY=

# Defaults used by the CLI when flags are omitted.
TUTORBENCH_CANDIDATE_MODEL=anthropic:claude-sonnet-4-6
TUTORBENCH_JUDGE_MODEL=anthropic:claude-sonnet-4-6
TUTORBENCH_SOLVER_MODEL=anthropic:claude-sonnet-4-6
TUTORBENCH_PLANNER_MODEL=anthropic:claude-sonnet-4-6
TUTORBENCH_VERIFIER_MODEL=anthropic:claude-sonnet-4-6
TUTORBENCH_CRITIC_MODEL=anthropic:claude-sonnet-4-6
TUTORBENCH_MAX_REVISION_ATTEMPTS=2
