.DS_Store
.env
.venv/
__pycache__/
.pytest_cache/
.ruff_cache/

# TutorBench data is large and license-sensitive. Never commit it.
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Runs can contain proprietary model outputs and API metadata.
runs/*
!runs/.gitkeep

# Local notebooks/scratch
scratch/
*.ipynb
