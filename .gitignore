.DS_Store
.env
.venv/
__pycache__/
.pytest_cache/
.ruff_cache/

# TutorBench data is large and license-sensitive. Never commit it.
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Keep raw traces private, but allow small sanitized result summaries for sharing.
runs/*
!runs/.gitkeep
!runs/*/
runs/*/*.jsonl
!runs/*/scores*.json
!runs/*/analysis.json
!runs/*/analysis.md
!runs/*/report*.md
!runs/*/compare*.md

# Local notebooks/scratch
scratch/
*.ipynb
